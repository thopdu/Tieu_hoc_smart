rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'grade', 'totalPoints', 'badges', 'createdAt']) &&
             data.uid is string &&
             data.displayName is string &&
             data.displayName.size() <= 100 &&
             data.email is string &&
             data.grade >= 1 && data.grade <= 5 &&
             data.totalPoints is number &&
             data.badges is list &&
             data.createdAt is int;
    }

    function isValidExamResult(data) {
      return data.keys().hasAll(['userId', 'subject', 'score', 'completedAt', 'xpEarned']) &&
             data.userId == request.auth.uid &&
             data.subject is string &&
             data.score is number &&
             data.completedAt is int &&
             data.xpEarned is number;
    }

    match /users/{userId} {
      allow read: if true; 
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && 
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'grade', 'totalPoints', 'badges', 'lastSession'])
                      );
    }

    match /results/{resultId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }
  }
}
