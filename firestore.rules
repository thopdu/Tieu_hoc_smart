rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSystemAdmin() {
      return isSignedIn() && 
             request.auth.token != null &&
             request.auth.token.email != null &&
             (request.auth.token.email == 'pvantho@pdu.edu.vn' || 
              request.auth.token.email.matches('(?i).*admin.*'));
    }

    function isAdmin() {
      return isSignedIn() && (
        isSystemAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'grade', 'totalPoints', 'badges', 'createdAt']) &&
             data.uid is string &&
             data.displayName is string &&
             data.displayName.size() <= 100 &&
             data.email is string &&
             data.grade is number &&
             data.totalPoints is number &&
             data.badges is list &&
             data.createdAt is number;
    }

    function isValidExamResult(data) {
      return data.keys().hasAll(['userId', 'subject', 'grade', 'score', 'completedAt', 'xpEarned']) &&
             data.userId == request.auth.uid &&
             data.subject is string &&
             data.grade is number &&
             data.score is number &&
             data.completedAt is number &&
             data.xpEarned is number;
    }

    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data) && (
        isSystemAdmin() || 
        (request.resource.data.role == 'user' && request.resource.data.membership == 'regular')
      );
      allow update: if (
        isAdmin() ||
        (isOwner(userId) && (
          // Option 1: Owner updates normal fields (excluding role/membership)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName', 'grade', 'totalPoints', 'badges', 'lastSession', 'photoURL'
          ]) ||
          // Option 2: Owner initializes their own profile (setting default values or if system admin)
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'displayName', 'grade', 'totalPoints', 'badges', 'lastSession', 'photoURL', 'role', 'membership'
            ]) && (
              isSystemAdmin() || (
                request.resource.data.role == 'user' && 
                request.resource.data.membership == 'regular'
              )
            )
          )
        ))
      );
      allow delete: if false;
    }

    match /results/{resultId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidExamResult(request.resource.data);
      allow update, delete: if false; 
    }
  }
}
